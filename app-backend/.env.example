# Application Configuration
APP_NAME="CMatrix"
APP_VERSION="0.0.1"
DEBUG=false

# CORS Configuration
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Security (Optional)
SECRET_KEY=your_secret_key_here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Command Execution
COMMAND_TIMEOUT=30
ENABLE_SUDO=false

# Logging
LOG_LEVEL=INFO
