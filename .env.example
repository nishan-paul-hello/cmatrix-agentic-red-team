# Application Configuration
APP_NAME="CMatrix"
APP_VERSION="0.0.1"
DEBUG=false

# Database
DATABASE_URL=

# Security & JWT
SECRET_KEY=your-secret-key-change-this-in-production-make-it-very-long-and-random-abc123xyz789
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Vector Database (Qdrant)
QDRANT_URL=http://localhost:6333
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION_NAME=cmatrix_memory

# Embeddings
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DEVICE=cpu

# Command Execution
COMMAND_TIMEOUT=30
ENABLE_SUDO=false

# Logging
LOG_LEVEL=INFO
