# Development Dockerfile for Next.js Frontend
FROM node:20-alpine

# Set the working directory
WORKDIR /app

# Ensure the working directory is owned by the node user
RUN chown -R node:node /app

# Switch to the node user
USER node

# Copy package files (ownership will be preserved by USER node)
COPY --chown=node:node package.json ./

# Install dependencies
RUN npm install --legacy-peer-deps

# Copy entrypoint script
COPY --chown=node:node docker-entrypoint.sh /docker-entrypoint.sh
# As /app is owned by node, but the entrypoint is at / we need to handle this
USER root
RUN chmod +x /docker-entrypoint.sh
USER node

# Copy the rest of the application
COPY --chown=node:node . .

# Expose the port
EXPOSE 3000

# Use entrypoint to fix permissions
ENTRYPOINT ["/docker-entrypoint.sh"]

# Start development server
CMD ["npm", "run", "dev"]
